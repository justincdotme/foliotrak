APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=foliotrak
DB_USERNAME=foliotrak
DB_PASSWORD=secret
# Root password for the bundled MySQL container.
DB_ROOT_PASSWORD=secret
# Host interface and port MySQL is published on, for host-side tools.
DB_FORWARD_HOST=127.0.0.1
DB_FORWARD_PORT=3306

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:5173
NGINX_SERVER_NAME=localhost
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Absolute path for uploaded photos; defaults to storage/app/uploads.
# PHOTOS_DISK_ROOT=
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Meilisearch powers typo-tolerant plant search (Laravel Scout). The key must match
# the meilisearch container's MEILI_MASTER_KEY; change it for a real install.
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=foliotrak_local_meili_master_key
# Meilisearch runs in production mode, which requires a key of at least 16 chars and
# disables the bundled web UI. Set development only if you publish its port for the UI.
MEILI_ENV=production

# GBIF species suggest. Defaults are safe; override the User-Agent contact for
# your install. Throttle and breaker guard the shared IP against an upstream block.
GBIF_BASE_URL=https://api.gbif.org/v1
# Bulk backbone export the species seed is built from (species:refresh-seed).
GBIF_BACKBONE_URL=https://hosted-datasets.gbif.org/datasets/backbone/current/backbone.zip
GBIF_USER_AGENT="Foliotrak/1.0 (+https://github.com/justincdotme/foliotrak)"
GBIF_TIMEOUT=5
GBIF_MATCH_MIN_CONFIDENCE=80
GBIF_CACHE_TTL_DAYS=90
GBIF_THROTTLE_MAX_ATTEMPTS=30
GBIF_THROTTLE_DECAY_SECONDS=60
GBIF_BREAKER_BASE_COOLDOWN_SECONDS=30
GBIF_BREAKER_MAX_COOLDOWN_SECONDS=600

# Pushover application token for care reminders. Each user adds their own
# recipient key in Settings; leave blank to disable reminder delivery.
PUSHOVER_TOKEN=

VITE_APP_NAME="${APP_NAME}"

FOLIOTRAK_ADMIN_EMAIL=admin@foliotrak.test
FOLIOTRAK_ADMIN_PASSWORD=testing123

# Display unit for sensor temperatures: F or C.
FOLIOTRAK_TEMPERATURE_UNIT=F

# Uid/gid the containers run as, so files written to the bind mounts stay
# owned by you. init.sh sets these to the invoking user automatically; set
# them by hand (`id -u` / `id -g`) only if you skip init.sh.
FOLIOTRAK_UID=1000
FOLIOTRAK_GID=1000

SENSOR_BASE_URL=
SENSOR_API_KEY=
SENSOR_GRANULARITY=30
SENSOR_TLS_VERIFY=false
