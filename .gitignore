# Docker bind-mounted MySQL data and generated TLS certs. Keep the certs
# directory in the repo so Docker does not root-create it on first boot.
/docker/data
/docker/nginx/certs/*
!/docker/nginx/certs/.gitkeep

# Linked git worktrees
.worktrees/

# Dusk test artifacts (screenshots, console logs, page source on failure)
/tests/Browser/screenshots
/tests/Browser/console
/tests/Browser/source

# Gondola gateway SQLite database (not part of this project)
readings.db
