#!/usr/bin/env bash
# Run the PHP test suite against an isolated in-memory SQLite database so it
# never touches the dev MySQL data. The app container sets DB_CONNECTION=mysql
# and SCOUT_DRIVER=meilisearch as real env vars, which override phpunit.xml, so
# they are forced here via -e: sqlite for the DB, and Scout's collection engine
# so tests never reach the live Meilisearch container. CI runs `php artisan test`
# directly on a clean runner where no conflicting env is present.
set -euo pipefail
exec docker compose run --rm --no-deps \
  -e APP_ENV=testing \
  -e DB_CONNECTION=sqlite \
  -e DB_DATABASE=:memory: \
  -e SCOUT_DRIVER=collection \
  app php artisan test "$@"
